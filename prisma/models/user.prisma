model User {
  id              Int               @id @default(autoincrement())
  username        String            @unique
  name            String
  surname         String
  avatar          String
password        String
  email           String            @unique
  contactOf       Contact[]         @relation(name: "ContactUser")
  contacts        Contact[]         @relation(name: "ContactOwner")
  chatParticipant ChatParticipant[]
  messages        Message[]
}
